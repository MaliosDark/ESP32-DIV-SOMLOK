# ── GitHub Linguist overrides ─────────────────────────────────────────────────

# Arduino source → count as Arduino
*.ino linguist-language=Arduino linguist-detectable=true

# Build output: generated, skip in stats
firmware/**/build/** linguist-generated=true

# Binary / asset blobs: not code, skip
*.bin linguist-detectable=false
*.gif linguist-detectable=false
*.mp4 linguist-detectable=false
*.zip linguist-detectable=false
*.sblv linguist-detectable=false
